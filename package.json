{
  "name": "flakiness-experiment",
  "version": "1.0.0",
  "private": true,
  "description": "Controlled flakiness experiment scaffold: SUT (Express), Playwright tests, harness, and ML pipeline stubs.",
  "scripts": {
    "start": "node sut/server.js",
    "dev": "NODE_ENV=development nodemon sut/server.js",
    "test:playwright": "npx playwright test",
    "harness": "node harness/orchestrator.js",
    "ml:train": "python3 ml/train.py"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "nodemon": "^2.0.22",
    "playwright": "^1.35.0"
  }
}
